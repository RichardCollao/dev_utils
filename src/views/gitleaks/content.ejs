<!-- Gitleaks -->
<div class="row mt-3 g-2 align-items-end">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="mb-0"><i class="bi bi-shield-lock"></i> Gitleaks</h3>
    </div>
    <hr>

    <div class="col-md-4">
        <label for="selGitleaksProject" class="form-label">PROYECTO</label>
        <select id="selGitleaksProject" class="form-select form-select-sm" aria-label="Seleccionar proyecto" disabled>
            <option value="" selected disabled>Seleccionar proyecto</option>
        </select>
    </div>

    <div class="col-md-3">
        <div class="form-label d-block invisible" aria-hidden="true">OPCIÓN</div>
        <div class="d-flex align-items-center justify-content-center gap-2 pb-1">
                <input class="form-check-input m-0" type="checkbox" value="1" id="chkExcludeGitIgnored" checked>
                <label class="form-check-label mb-0" for="chkExcludeGitIgnored">
                    Excluir archivos <b>.gitignore</b>
                </label>
        </div>
    </div>

    <div class="col-md-5">
        <fieldset class="mb-0">
        <legend class="form-label fs-6 mb-1">Modo</legend>
        <div class="btn-group btn-group-sm" aria-label="Modo Gitleaks">
            <input class="btn-check" type="radio" name="gitleaksMode" id="gitleaksModeGit" value="git" autocomplete="off">
            <label class="btn btn-outline-secondary" for="gitleaksModeGit">Git</label>

            <input class="btn-check" type="radio" name="gitleaksMode" id="gitleaksModeDir" value="dir" autocomplete="off" checked>
            <label class="btn btn-outline-secondary" for="gitleaksModeDir">Dir</label>
        </div>
        </fieldset>
    </div>
</div>

<hr>

<div class="row mt-3">
    <div class="col-md-4">
        <i class="bi bi-terminal"></i> Consola Gitleaks
    </div>
    <div class="col-md-8 text-end">
        <button type="button" id="btnDownloadGitleaksPdf" class="btn btn-sm btn-outline-secondary" disabled>
            <i class="bi bi-file-earmark-pdf me-1"></i>Descargar PDF
        </button>
        <button type="button" id="btnRunGitleaks" class="btn btn-sm btn-outline-secondary" disabled>
            <i class="bi bi-terminal me-2"></i>Gitleaks
        </button>
        <button type="button" id="btnClearGitleaksConsole" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-eraser me-1"></i>Limpiar
        </button>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-12">
        <div id="gitleaksTerminal" class="scanner-terminal">
            <div id="gitleaksTerminalInner" class="scanner-terminal-inner"></div>
        </div>
    </div>
</div>





    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const projectSelect = document.querySelector('#selGitleaksProject');
            if (projectSelect) {
                projectSelect.addEventListener('change', updateRunGitleaksButtonState);
                projectSelect.addEventListener('change', updateGitleaksModeForSelection);
            }

            updateRunGitleaksButtonState();
            updateGitleaksModeForSelection();
            loadGitleaksProjects();
        });

        function updateRunGitleaksButtonState() {
            const projectSelect = document.querySelector('#selGitleaksProject');
            const button = document.querySelector('#btnRunGitleaks');
            const pdfButton = document.querySelector('#btnDownloadGitleaksPdf');
            if (!button) return;

            const hasProject = !!(projectSelect && projectSelect.value);
            button.disabled = !hasProject;

            // Resetear estado del botón PDF cuando cambie la selección
            if (pdfButton) {
                pdfButton.disabled = true;
            }
        }

        function updateGitleaksModeForSelection() {
            const select = document.querySelector('#selGitleaksProject');
            const gitRadio = document.querySelector('#gitleaksModeGit');
            const gitLabel = document.querySelector('label[for="gitleaksModeGit"]');
            const dirRadio = document.querySelector('#gitleaksModeDir');
            const help = document.querySelector('#gitleaksModeHelp');

            if (!gitRadio || !dirRadio) return;

            const directory = String(select?.value || '').trim();

            if (!directory) {
                gitRadio.disabled = true;
                if (gitLabel) gitLabel.classList.add('disabled');
                dirRadio.checked = true;
                if (help) help.textContent = 'Selecciona un proyecto para elegir el modo.';
                return;
            }

            request(`/api/gitleaks/project-metadata?directory=${encodeURIComponent(directory)}`, 'GET', null, function (response) {
                const isGitRepo = !!response?.data?.isGitRepo;

                gitRadio.disabled = !isGitRepo;
                if (gitLabel) gitLabel.classList.toggle('disabled', !isGitRepo);

                if (isGitRepo) {
                    gitRadio.checked = true;
                } else {
                    dirRadio.checked = true;
                }
            }, function () {
                gitRadio.disabled = true;
                if (gitLabel) gitLabel.classList.add('disabled');
                dirRadio.checked = true;
                if (help) help.textContent = 'No fue posible verificar el tipo de proyecto.';
            });
        }

        function loadGitleaksProjects() {
            request('/api/projects', 'GET', null, function(response) {
                const projects = Array.isArray(response?.data) ? response.data : [];
                const select = document.querySelector('#selGitleaksProject');
                if (!select) return;

                const options = ['<option value="" selected disabled>Seleccionar proyecto</option>']
                    .concat(projects.map(function(obj) {
                        return `<option value="${obj.projectBaseDir || ''}">${obj.projectName || ''}</option>`;
                    }));

                select.innerHTML = options.join('\n');
                select.disabled = projects.length === 0;
                updateRunGitleaksButtonState();
                updateGitleaksModeForSelection();
            });
        }
    </script>