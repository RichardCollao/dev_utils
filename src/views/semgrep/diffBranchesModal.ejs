<!-- Modal: Diff Branches Semgrep -->
<div class="modal fade" id="modalSemgrepDiff" tabindex="-1" aria-labelledby="modalSemgrepDiffLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalSemgrepDiffLabel">Comparar ramas</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="selSemgrepBase" class="form-label fw-semibold">Base</label>
          <select id="selSemgrepBase" class="form-select"></select>
        </div>
        <div class="mb-3">
          <label for="selSemgrepCompare" class="form-label fw-semibold">Compare</label>
          <select id="selSemgrepCompare" class="form-select"></select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        <button type="button" class="btn btn-primary" onclick="confirmSemgrepDiff()">Comparar</button>
      </div>
    </div>
  </div>
</div>
