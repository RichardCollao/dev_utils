<div id="explorerRoot" data-path="<%= path %>" data-items="<%- encodeURIComponent(JSON.stringify(items || [])) %>">
    <% if (error) { %>
        <div class="alert alert-danger mb-0" role="alert"><%= error %></div>
    <% } else { %>
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0" id="explorerBreadcrumb"></ol>
        </nav>

        <div class="list-group" id="explorerList"></div>
        <p class="text-muted small mt-3 mb-0 d-none" id="explorerEmptyMessage">Esta carpeta está vacía.</p>
    <% } %>
</div>
